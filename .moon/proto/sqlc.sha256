# SHA-256 of the sqlc 1.31.1 binary, per platform (os_arch -> hex digest).
#
# Why this file exists: sqlc's GitHub release publishes archives only — no
# checksum file and no signature — so the Proto plugin (.moon/proto/sqlc.toml)
# cannot verify the download via checksum-url the way goose/mockery/golangci-lint
# do. The `sqlc-verify` moon task instead checks the resolved sqlc binary against
# the digest below BEFORE any sqlc task runs, so a substituted release archive is
# caught (CWE-494). This is the repository-provided expected digest.
#
# Trust anchor: each value was produced by downloading the release archive,
# verifying it against GitHub's published per-asset digest, then extracting and
# hashing the `sqlc` binary.
#
# Regenerate on a version bump (also bump .prototools), then commit:
#   V=<new-version>
#   for k in darwin_arm64 darwin_amd64 linux_amd64 linux_arm64; do
#     os=${k%_*}; arch=${k#*_}; f="sqlc_${V}_${k}.tar.gz"
#     want=$(gh api repos/sqlc-dev/sqlc/releases/tags/v${V} \
#       --jq ".assets[]|select(.name==\"$f\").digest" | sed 's/sha256://')
#     curl -fsSL -o "$f" "https://github.com/sqlc-dev/sqlc/releases/download/v${V}/$f"
#     got=$(shasum -a 256 "$f" | cut -d' ' -f1)
#     [ "$got" = "$want" ] || { echo "archive digest mismatch: $k"; exit 1; }
#     tar -xzf "$f" sqlc && printf '%-13s %s\n' "$k" "$(shasum -a 256 sqlc|cut -d' ' -f1)"
#   done
#
darwin_arm64  7e63a8b2166f1103a2ad1d2e5d05d8fe3f13ca65ecf2774a2570b830d32055fd
darwin_amd64  359730e2fbfdb5480dd90389bd2987a5dad00fc7510a330df749c6bc6987c1af
linux_amd64   0496fbc18f603e2fbd10c752942d1389a1fa9bc3d18de7243ec00cccd611575f
linux_arm64   3b42bdbc5be1d534b95fc6b9f0e1572e6aa555fda3c96f208cb26abb1bb77d7e
