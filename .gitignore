# Moon
.moon/cache/
.moon/docker/

# Agent/runtime state. `.agents/skills` holds committed template skills; the
# entries below are local maintainer tooling and runtime state, not template
# content. `.codex-security/` is Codex scan output; `codex-security-scan` is a
# local scanning skill that lives under the otherwise-committed `.agents/skills`.
# `.claude` has no trailing slash so it matches whether it is a directory (the
# usual case) or a symlink into `.agents` (a local convenience) — a trailing
# slash would match only a real directory.
.claude
.journal/
.wt/
.codex-security/
.agents/skills/codex-security-scan/

# Environment
.env
.env.*
.envrc

# mise local overrides (per-developer tool/env overrides; never committed).
# mise.toml and mise.lock ARE committed.
mise.local.toml
.mise.local.toml

# Go
bin/
cover.out
coverage.out
coverage.html
*.test
*.prof
vendor/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
dist/
build/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/
!docs/.python-version

# Node / TypeScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/install-state.gz
.yarn/build-state.yml
*.tsbuildinfo
.turbo/
.next/
.nuxt/
.svelte-kit/
coverage/

# Template repo outputs
docs/build/
docs/.venv/

# sqlc-check throwaway regeneration dir/config (cleaned up on success; ignored
# so an interrupted run never leaks into the tree)
.sqlc-check.*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
